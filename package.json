{
	"name": "tporret-api-data-importer",
	"version": "1.3.1",
	"private": true,
	"description": "Frontend assets for tporret API Data Importer dashboard.",
	"scripts": {
		"build": "wp-scripts build",
		"check:metadata": "node scripts/check-release-metadata.mjs",
		"check:php": "find . \\( -path './vendor' -o -path './node_modules' -o -path './.dist' -o -path './.svn-release' \\) -prune -o -name '*.php' -print0 | xargs -0 -n1 php -l",
		"release:check": "npm run check:metadata && npm run check:php && npm run build",
		"start": "wp-scripts start",
		"test": "npm run check:metadata"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0",
		"tailwindcss": "^3.4.0",
		"postcss": "^8.4.0",
		"autoprefixer": "^10.4.0"
	},
	"dependencies": {
		"recharts": "^2.15.0",
		"lucide-react": "^0.500.0"
	}
}
