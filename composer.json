{
    "name": "tporret/enterprise-api-importer",
    "description": "Enterprise ETL importer plugin for WordPress.",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "twig/twig": "^3.24",
        "sabre/vobject": "^4"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "scripts": {
        "phpcs": "vendor/bin/phpcs --runtime-set ignore_errors_on_exit 1 --runtime-set ignore_warnings_on_exit 1",
        "phpcbf": "vendor/bin/phpcbf"
    }
}
